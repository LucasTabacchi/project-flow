generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum BoardRole {
  OWNER
  EDITOR
  VIEWER
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
}

enum CardPriority {
  LOW
  MEDIUM
  HIGH
}

enum CardStatus {
  TODO
  IN_PROGRESS
  IN_REVIEW
  DONE
  BLOCKED
}

enum LabelColor {
  SLATE
  SKY
  EMERALD
  AMBER
  ROSE
  VIOLET
}

enum NotificationType {
  CARD_ASSIGNED
  CARD_COMMENT
  CARD_MENTION
  BOARD_INVITATION
  INVITATION_ACCEPTED
  INVITATION_DECLINED
}

enum ActivityType {
  CARD_CREATED
  CARD_MOVED
  CARD_RENAMED
  CARD_STATUS_CHANGED
  CARD_ASSIGNED
  CARD_COMMENT_ADDED
  CARD_DUE_DATE_SET
  CARD_DUE_DATE_REMOVED
  LIST_CREATED
  LIST_RENAMED
  MEMBER_JOINED
  // Nuevos para Ronda 1
  CARD_TIME_LOGGED
}

model User {
  id                      String            @id @default(cuid())
  name                    String
  email                   String            @unique
  passwordHash            String
  avatarUrl               String?
  bio                     String?
  createdAt               DateTime          @default(now())
  updatedAt               DateTime          @updatedAt
  sessions                Session[]
  ownedBoards             Board[]           @relation("BoardOwner")
  boardMemberships        BoardMember[]
  createdCards            Card[]            @relation("CardCreator")
  comments                CardComment[]
  cardAssignments         CardAssignment[]
  completedChecklistItems ChecklistItem[]   @relation("ChecklistItemCompletedBy")
  sentInvitations         BoardInvitation[] @relation("BoardInvitationInvitedBy")
  receivedInvitations     BoardInvitation[] @relation("BoardInvitationInvitee")
  attachments             Attachment[]      @relation("AttachmentUploader")
  boardPresences          BoardPresence[]
  notifications           Notification[]
  activities              BoardActivity[]
  timeEntries             TimeEntry[]
  commentReactions        CommentReaction[]
  boardTemplates          BoardTemplate[]
  recurringCards          RecurringCard[]
}

model Session {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Board {
  id              String            @id @default(cuid())
  name            String
  description     String?
  theme           String            @default("aurora")
  backgroundColor String?
  ownerId         String
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  owner           User              @relation("BoardOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members         BoardMember[]
  invitations     BoardInvitation[]
  lists           List[]
  cards           Card[]
  labels          Label[]
  presences       BoardPresence[]
  activities      BoardActivity[]
  webhooks        Webhook[]
  recurringCards  RecurringCard[]

  @@index([ownerId])
  @@index([updatedAt])
}

model BoardMember {
  id        String    @id @default(cuid())
  boardId   String
  userId    String
  role      BoardRole @default(EDITOR)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  board     Board     @relation(fields: [boardId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([boardId, userId])
  @@index([userId])
}

model BoardInvitation {
  id          String           @id @default(cuid())
  boardId     String
  email       String
  role        BoardRole        @default(VIEWER)
  status      InvitationStatus @default(PENDING)
  invitedById String
  inviteeId   String?
  token       String           @unique
  expiresAt   DateTime
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  board       Board            @relation(fields: [boardId], references: [id], onDelete: Cascade)
  invitedBy   User             @relation("BoardInvitationInvitedBy", fields: [invitedById], references: [id], onDelete: Cascade)
  invitee     User?            @relation("BoardInvitationInvitee", fields: [inviteeId], references: [id], onDelete: SetNull)

  @@unique([boardId, email])
  @@index([email, status])
}

model List {
  id        String   @id @default(cuid())
  boardId   String
  name      String
  position  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  board     Board    @relation(fields: [boardId], references: [id], onDelete: Cascade)
  cards     Card[]
  recurringCards RecurringCard[]

  @@index([boardId, position])
}

model Card {
  id                String          @id @default(cuid())
  boardId           String
  listId            String
  createdById       String
  title             String
  description       String?
  position          Int
  status            CardStatus      @default(TODO)
  priority          CardPriority    @default(MEDIUM)
  dueDate           DateTime?
  completedAt       DateTime?
  coverColor        String?
  // ── Ronda 1: tiempo estimado y tracking ──
  estimatedMinutes  Int?
  trackedMinutes    Int             @default(0)
  // ──────────────────────────────────────────
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  board             Board           @relation(fields: [boardId], references: [id], onDelete: Cascade)
  list              List            @relation(fields: [listId], references: [id], onDelete: Cascade)
  createdBy         User            @relation("CardCreator", fields: [createdById], references: [id], onDelete: Cascade)
  comments          CardComment[]
  checklists        CardChecklist[]
  cardLabels        CardLabel[]
  assignments       CardAssignment[]
  attachments       Attachment[]
  presences         BoardPresence[]
  timeEntries       TimeEntry[]
  recurringSourceId String?        // FK to RecurringCard if spawned
  recurringSource   RecurringCard?  @relation("SpawnedFromRecurring", fields: [recurringSourceId], references: [id], onDelete: SetNull)

  @@index([boardId, dueDate])
  @@index([boardId, status])
  @@index([listId, position])
}

// ── Ronda 1: registro de sesiones de trabajo ──────────────────────────────────
model TimeEntry {
  id         String    @id @default(cuid())
  cardId     String
  userId     String
  startedAt  DateTime
  endedAt    DateTime?
  minutes    Int?
  note       String?
  createdAt  DateTime  @default(now())
  card       Card      @relation(fields: [cardId], references: [id], onDelete: Cascade)
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([cardId, startedAt])
  @@index([userId, startedAt])
}
// ─────────────────────────────────────────────────────────────────────────────

model BoardPresence {
  id           String   @id @default(cuid())
  boardId      String
  userId       String
  clientId     String
  activeCardId String?
  activeField  String?
  lastSeenAt   DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  board        Board    @relation(fields: [boardId], references: [id], onDelete: Cascade)
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  activeCard   Card?    @relation(fields: [activeCardId], references: [id], onDelete: SetNull)

  @@unique([boardId, userId, clientId])
  @@index([boardId, lastSeenAt])
  @@index([activeCardId, lastSeenAt])
}

model CardComment {
  id        String   @id @default(cuid())
  cardId    String
  authorId  String
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  card      Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  reactions CommentReaction[]

  @@index([cardId, createdAt])
}

model CardChecklist {
  id        String          @id @default(cuid())
  cardId    String
  title     String
  position  Int
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  card      Card            @relation(fields: [cardId], references: [id], onDelete: Cascade)
  items     ChecklistItem[]

  @@index([cardId, position])
}

model ChecklistItem {
  id            String         @id @default(cuid())
  checklistId   String
  title         String
  position      Int
  isCompleted   Boolean        @default(false)
  completedAt   DateTime?
  completedById String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  checklist     CardChecklist  @relation(fields: [checklistId], references: [id], onDelete: Cascade)
  completedBy   User?          @relation("ChecklistItemCompletedBy", fields: [completedById], references: [id], onDelete: SetNull)

  @@index([checklistId, position])
}

model Label {
  id        String      @id @default(cuid())
  boardId   String
  name      String
  color     LabelColor
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  board     Board       @relation(fields: [boardId], references: [id], onDelete: Cascade)
  cards     CardLabel[]

  @@unique([boardId, name])
  @@index([boardId])
}

model CardLabel {
  cardId    String
  labelId   String
  createdAt DateTime @default(now())
  card      Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)
  label     Label    @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@id([cardId, labelId])
  @@index([labelId])
}

model CardAssignment {
  cardId    String
  userId    String
  createdAt DateTime @default(now())
  card      Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([cardId, userId])
  @@index([userId])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  href      String?
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read, createdAt])
}

model BoardActivity {
  id        String       @id @default(cuid())
  boardId   String
  userId    String
  type      ActivityType
  // Texto legible: "movió 'Diseño UI' a En revisión"
  summary   String
  // Metadata opcional en JSON: { cardId, cardTitle, fromList, toList, ... }
  meta      Json?
  createdAt DateTime     @default(now())
  board     Board        @relation(fields: [boardId], references: [id], onDelete: Cascade)
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([boardId, createdAt])
}

model Attachment {
  id           String   @id @default(cuid())
  cardId       String
  uploadedById String?
  name         String
  url          String
  size         Int?
  mimeType     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  card         Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)
  uploadedBy   User?    @relation("AttachmentUploader", fields: [uploadedById], references: [id], onDelete: SetNull)

  @@index([cardId, createdAt])
}

// ── Ronda 3: reacciones en comentarios ───────────────────────────────────────
model CommentReaction {
  id        String      @id @default(cuid())
  commentId String
  userId    String
  emoji     String      // e.g. "👍" "❤️" "🎉"
  createdAt DateTime    @default(now())
  comment   CardComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId, emoji])
  @@index([commentId])
}
// ─────────────────────────────────────────────────────────────────────────────

// ── Ronda 3: plantillas de tablero ────────────────────────────────────────────
model BoardTemplate {
  id          String   @id @default(cuid())
  ownerId     String
  name        String
  description String?
  theme       String   @default("aurora")
  // Snapshot JSON de listas+tarjetas: { lists: [{name, cards: [{title,description,priority,status}]}] }
  snapshot    Json
  isPublic    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  owner       User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([ownerId])
  @@index([isPublic])
}
// ─────────────────────────────────────────────────────────────────────────────

// ── Ronda 3: webhooks salientes ───────────────────────────────────────────────
model Webhook {
  id        String    @id @default(cuid())
  boardId   String
  url       String
  secret    String    // HMAC-SHA256 signing secret
  // Eventos suscritos: ["card.created","card.moved","card.status_changed","comment.added"]
  events    String[]
  active    Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  board     Board     @relation(fields: [boardId], references: [id], onDelete: Cascade)
  deliveries WebhookDelivery[]

  @@index([boardId, active])
}

model WebhookDelivery {
  id          String   @id @default(cuid())
  webhookId   String
  event       String
  payload     Json
  statusCode  Int?
  success     Boolean  @default(false)
  attempt     Int      @default(1)
  createdAt   DateTime @default(now())
  webhook     Webhook  @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@index([webhookId, createdAt])
}
// ─────────────────────────────────────────────────────────────────────────────

// ── Ronda 3: tarjetas recurrentes ────────────────────────────────────────────
enum RecurrenceFrequency {
  DAILY
  WEEKLY
  BIWEEKLY
  MONTHLY
}

model RecurringCard {
  id            String               @id @default(cuid())
  boardId       String
  listId        String
  createdById   String
  title         String
  description   String?
  priority      CardPriority         @default(MEDIUM)
  frequency     RecurrenceFrequency
  // Día del próximo spawn (date only, sin hora)
  nextDueAt     DateTime
  // Cuántos días de antelación crear la tarjeta antes del nextDueAt
  leadDays      Int                  @default(0)
  active        Boolean              @default(true)
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  board         Board                @relation(fields: [boardId], references: [id], onDelete: Cascade)
  list          List                 @relation(fields: [listId], references: [id], onDelete: Cascade)
  createdBy     User                 @relation(fields: [createdById], references: [id], onDelete: Cascade)
  spawnedCards  Card[]               @relation("SpawnedFromRecurring")

  @@index([active, nextDueAt])
  @@index([boardId])
}
// ─────────────────────────────────────────────────────────────────────────────
