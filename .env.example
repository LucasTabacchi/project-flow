# Runtime Next.js / serverless
DATABASE_URL="postgresql://prisma.<PROJECT-REF>:<PASSWORD>@aws-0-<REGION>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# Prisma CLI / migrations
DIRECT_URL="postgresql://prisma.<PROJECT-REF>:<PASSWORD>@aws-0-<REGION>.pooler.supabase.com:5432/postgres"

# Opcional: nombre personalizado para la cookie de sesión
SESSION_COOKIE_NAME="projectflow_session"

# URL pública usada para construir enlaces de invitación
APP_URL="http://localhost:3000"

# Envío de emails con Brevo (ex Sendinblue) — https://app.brevo.com
# No requiere dominio propio, funciona con Gmail verificado.
# Plan gratuito: 300 emails/día.
BREVO_API_KEY="xkeysib-..."
EMAIL_FROM_ADDRESS="tu@gmail.com"
EMAIL_FROM_NAME="ProjectFlow"

# Redis Pub/Sub con Upstash — opcional, mejora la colaboración multi-instancia
# Sin esto el sistema funciona igual pero solo en una instancia de Vercel
# Crear cuenta en https://console.upstash.com → crear DB Redis → copiar REST URL y token
UPSTASH_REDIS_REST_URL="https://YOUR-DB.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your_token_here"

# ── Ronda 3: nuevas variables ──────────────────────────────────────────────────

# Cron job para tarjetas recurrentes
# Configura el mismo valor en tu proveedor de cron (ej: cron-job.org o Vercel Cron)
# CRON_SECRET="un-secreto-largo-y-aleatorio"

# Receptor de webhooks de ProjectFlow en Vercel Function
# Copiá el secret generado en la configuración del webhook del tablero.
# Endpoint sugerido en producción:
# https://tu-dominio.com/api/webhooks/projectflow
PROJECTFLOW_WEBHOOK_SECRET="otro-secreto-largo-y-aleatorio"

# Tolerancia máxima para aceptar webhooks firmados (en milisegundos)
# Opcional. Si no se define, usa 5 minutos.
# PROJECTFLOW_WEBHOOK_TOLERANCE_MS="300000"

# Caché Redis (opcional, mejora performance en producción)
# UPSTASH_REDIS_REST_URL y UPSTASH_REDIS_REST_TOKEN ya estaban en este archivo
# Si están configurados, la caché se activa automáticamente.
